<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <ImageView
            android:id="@+id/album"
            android:layout_width="163dp"
            android:layout_height="163dp"
            android:layout_marginLeft="8dp"
            android:layout_marginTop="5dp"
            android:layout_marginRight="2dp"/>
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <ImageButton
                android:id="@+id/curplaylist"
                android:layout_width="85dp"
                android:layout_height="44dp"
                android:layout_marginTop="14dp"
                android:src="@drawable/ic_mp_current_playlist_btn"
                style="?android:attr/buttonBarButtonStyle"/>
            <ImageButton
                android:id="@+id/shuffle"
                android:layout_width="85dp"
                android:layout_height="44dp"
                android:layout_marginTop="10dp"
                style="?android:attr/buttonBarButtonStyle"/>
            <ImageButton
                android:id="@+id/repeat"
                android:layout_width="85dp"
                android:layout_height="44dp"
                android:layout_marginTop="10dp"
                style="?android:attr/buttonBarButtonStyle"/>
        </LinearLayout>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:paddingLeft="11dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false">
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="4dp"
            android:src="@drawable/ic_tab_artists"/>
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:layout_gravity="center_vertical"
            android:id="@+id/artistname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:paddingLeft="11dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false">
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="4dp"
            android:src="@drawable/ic_tab_albums"/>
        <TextView
            android:textSize="14sp"
            android:ellipsize="end"
            android:layout_gravity="center_vertical"
            android:id="@+id/albumname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:paddingLeft="11dp"
        android:paddingTop="0dp"
        android:paddingBottom="4dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false">
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="4dp"
            android:src="@drawable/ic_tab_songs"/>
        <TextView
            android:textSize="14sp"
            android:ellipsize="end"
            android:layout_gravity="center_vertical"
            android:id="@+id/trackname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"/>
    </LinearLayout>
    <include layout="@layout/audio_player_common"/>
</LinearLayout>
