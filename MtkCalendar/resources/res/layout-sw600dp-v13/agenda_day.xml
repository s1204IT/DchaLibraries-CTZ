<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/agenda_day_bar_background_color"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:rowCount="2"
    android:columnCount="2">
    <View
        android:id="@+id/top_divider_simple"
        android:background="@color/agenda_list_separator_color"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_column="0"
        android:layout_row="0"
        android:layout_rowSpan="1"
        android:layout_columnSpan="2"/>
    <View
        android:id="@+id/top_divider_past_present"
        android:background="@color/agenda_past_present_separator_color"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_column="0"
        android:layout_row="0"
        android:layout_rowSpan="1"
        android:layout_columnSpan="2"/>
    <TextView
        android:textSize="24sp"
        android:textColor="@color/agenda_day_item_text_color"
        android:layout_gravity="center"
        android:id="@+id/date"
        android:paddingLeft="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:minHeight="42dp"
        android:layout_column="0"
        android:singleLine="true"
        android:layout_row="1"/>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/agenda_day_item_text_color"
        android:ellipsize="marquee"
        android:gravity="center_vertical"
        android:layout_gravity="center"
        android:id="@+id/day"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:layout_marginTop="2dp"
        android:layout_marginRight="@dimen/agenda_item_right_margin"
        android:minHeight="42dp"
        android:layout_column="1"
        android:singleLine="true"
        android:layout_row="1"/>
</GridLayout>
