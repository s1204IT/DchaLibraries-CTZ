<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/agenda_day_bar_background_color"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <View
        android:id="@+id/top_divider_simple"
        android:background="@color/agenda_list_separator_color"
        android:layout_width="match_parent"
        android:layout_height="1px"/>
    <View
        android:id="@+id/top_divider_past_present"
        android:background="@color/agenda_past_present_separator_color"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="2dp"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:minHeight="48dp">
        <TextView
            android:textSize="12sp"
            android:textColor="@color/agenda_day_item_text_color"
            android:id="@+id/day"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="-8dp"
            android:singleLine="true"/>
        <TextView
            android:textSize="24sp"
            android:textColor="@color/agenda_day_item_text_color"
            android:id="@+id/date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"/>
    </LinearLayout>
</LinearLayout>
