<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="SuwGlifButton.Tertiary" parent="@style/SuwGlifButton.BaseTertiary">
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="SuwEditText" parent="@android:style/Widget.Material.EditText">
        <item name="android:background">@drawable/suw_edittext_bg</item>
        <item name="android:paddingLeft">@dimen/suw_edit_text_padding_horizontal</item>
        <item name="android:paddingRight">@dimen/suw_edit_text_padding_horizontal</item>
        <item name="android:minHeight">@dimen/suw_edit_text_min_height</item>
    </style>
    <style name="SuwBase.ProgressBarLarge" parent="@android:style/Widget.Material.ProgressBar.Large">
    </style>
    <style name="TextAppearance.SuwDescription" parent="@android:style/TextAppearance.Material.Medium">
        <item name="android:textSize">@dimen/suw_description_text_size</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>
    <style name="TextAppearance.SuwCardTitle" parent="@android:style/TextAppearance.Material.Display1">
        <item name="android:textColor">@android:color/white</item>
    </style>
    <style name="SuwGlifCardBackground" parent="">
        <item name="android:background">?android:attr/colorPrimary</item>
    </style>
    <style name="SuwFourColorIndeterminateProgressBar" parent="@style/SuwBase.ProgressBarLarge">
        <item name="android:layout_gravity">0x11</item>
        <item name="android:indeterminate">true</item>
        <item name="android:indeterminateDrawable">@drawable/suw_fourcolor_progress_bar</item>
        <item name="android:indeterminateTint">@null</item>
        <item name="android:indeterminateTintMode">@null</item>
    </style>
    <style name="SuwItemContainer" parent="">
        <item name="android:paddingTop">@dimen/suw_items_padding_vertical</item>
        <item name="android:paddingBottom">@dimen/suw_items_padding_vertical</item>
        <item name="android:minHeight">?android:attr/listPreferredItemHeight</item>
        <item name="android:paddingStart">?android:attr/listPreferredItemPaddingStart</item>
        <item name="android:paddingEnd">?android:attr/listPreferredItemPaddingEnd</item>
    </style>
    <style name="SuwItemTitle" parent="">
        <item name="android:textAppearance">?android:attr/textAppearanceListItem</item>
    </style>
    <style name="SuwItemSummary" parent="">
        <item name="android:textAppearance">?android:attr/textAppearanceListItemSmall</item>
    </style>
    <style name="SuwNavBarButtonStyle" parent="@android:style/Widget.Material.Button.Borderless">
        <item name="android:textSize">@dimen/suw_navbar_text_size</item>
        <item name="android:textColor">?attr/suwNavBarTextColor</item>
        <item name="android:background">?attr/suwNavBarButtonBackground</item>
        <item name="android:paddingLeft">@dimen/suw_navbar_button_padding_sides</item>
        <item name="android:paddingRight">@dimen/suw_navbar_button_padding_sides</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    <style name="SuwNavBarThemeDark" parent="@style/SuwNavBarTheme">
        <item name="suwNavBarBackgroundColor">@color/suw_navbar_bg_dark</item>
        <item name="suwNavBarButtonBackground">@drawable/suw_navbar_btn_bg</item>
    </style>
    <style name="SuwNavBarThemeLight" parent="@style/SuwNavBarTheme">
        <item name="suwNavBarBackgroundColor">@color/suw_navbar_bg_light</item>
        <item name="suwNavBarButtonBackground">@drawable/suw_navbar_btn_bg</item>
    </style>
</resources>
