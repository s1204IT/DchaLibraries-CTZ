<?xml version="1.0" encoding="utf-8"?>
<com.android.systemui.qs.QuickStatusBarHeader xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="bottom|fill_horizontal"
    android:id="@+id/header"
    android:background="@android:color/transparent"
    android:paddingTop="0dp"
    android:clickable="false"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="@android:dimen/expanded_group_conversation_message_padding"
    android:baselineAligned="false"
    android:paddingStart="0dp"
    android:paddingEnd="0dp"
    android:elevation="4dp">
    <include layout="@layout/quick_status_bar_header_system_icons"/>
    <include layout="@layout/quick_qs_status_icons"/>
    <include layout="@layout/quick_settings_header_info"/>
    <com.android.systemui.qs.QuickQSPanel
        android:id="@+id/quick_qs_panel"
        android:focusable="true"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_below="@+id/quick_qs_status_icons"
        android:importantForAccessibility="yes"
        android:layout_marginStart="@dimen/qs_header_tile_margin_horizontal"
        android:layout_marginEnd="@dimen/qs_header_tile_margin_horizontal"
        android:accessibilityTraversalBefore="@+id/expand_indicator"
        android:accessibilityTraversalAfter="@+id/date_time_group"/>
    <com.android.systemui.statusbar.AlphaOptimizedImageView
        android:id="@+id/qs_detail_header_progress"
        android:background="@color/qs_detail_progress_track"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:src="@drawable/indeterminate_anim"
        android:layout_alignParentBottom="true"
        android:alpha="0"/>
    <TextView
        android:textSize="11dp"
        android:textStyle="bold"
        android:textColor="#00a040"
        android:layout_gravity="center_vertical"
        android:id="@+id/header_debug_info"
        android:padding="2dp"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-condensed"/>
</com.android.systemui.qs.QuickStatusBarHeader>
