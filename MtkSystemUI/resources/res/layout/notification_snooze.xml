<?xml version="1.0" encoding="utf-8"?>
<com.android.systemui.statusbar.NotificationSnooze xmlns:android="http://schemas.android.com/apk/res/android"
    android:theme="@android:style/Theme.DeviceDefault.Light"
    android:orientation="vertical"
    android:background="@color/notification_guts_bg_color"
    android:clickable="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@+id/notification_snooze"
        android:layout_width="match_parent"
        android:layout_height="@dimen/snooze_snackbar_min_height">
        <TextView
            android:textColor="#dd000000"
            android:id="@+id/snooze_option_default"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:paddingStart="@android:dimen/conversation_compact_face_pile_avatar_size"
            android:paddingEnd="4dp"
            android:layout_alignParentStart="true"/>
        <ImageView
            android:id="@+id/expand_button"
            android:paddingTop="1dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:tint="#9e9e9e"
            android:layout_centerVertical="true"
            android:layout_toEndOf="@+id/snooze_option_default"/>
        <TextView
            android:id="@+id/undo"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="@string/snooze_undo"
            android:layout_centerVertical="true"
            android:layout_marginEnd="@dimen/notification_guts_button_side_margin"
            android:layout_alignParentEnd="true"
            style="@style/TextAppearance.NotificationInfo.Button"/>
    </RelativeLayout>
    <View
        android:id="@+id/divider"
        android:background="#9e9e9e"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/snooze_options"
        android:paddingBottom="8dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</com.android.systemui.statusbar.NotificationSnooze>
