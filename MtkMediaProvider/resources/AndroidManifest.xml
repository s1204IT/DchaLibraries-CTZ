<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:androidprv="http://schemas.android.com/apk/prv/res/android" xmlns:android="http://schemas.android.com/apk/res/android"
    android:sharedUserId="android.media"
    android:versionCode="902"
    android:versionName="9"
    android:sharedUserLabel="@string/uid_label"
    android:compileSdkVersion="28"
    android:compileSdkVersionCodename="9"
    package="com.android.providers.media"
    platformBuildVersionCode="28"
    platformBuildVersionName="9">
    <uses-sdk
        android:minSdkVersion="28"
        android:targetSdkVersion="28"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <uses-permission android:name="android.permission.WRITE_SETTINGS"/>
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.WRITE_MEDIA_STORAGE"/>
    <uses-permission android:name="android.permission.ACCESS_MTP"/>
    <uses-permission android:name="android.permission.MANAGE_USERS"/>
    <uses-permission android:name="android.permission.INTERACT_ACROSS_USERS"/>
    <uses-permission android:name="android.permission.GET_TASKS"/>
    <uses-permission android:name="android.permission.READ_PHONE_STATE"/>
    <uses-permission android:name="android.permission.USE_RESERVED_DISK"/>
    <application
        android:label="@string/app_label"
        android:process="android.process.media"
        android:allowBackup="false"
        android:supportsRtl="true">
        <provider
            android:name="MediaProvider"
            android:exported="true"
            android:multiprocess="false"
            android:authorities="media">
            <grant-uri-permission android:pathPrefix="/external/"/>
            <path-permission
                android:readPermission="android.permission.READ_EXTERNAL_STORAGE"
                android:writePermission="android.permission.WRITE_EXTERNAL_STORAGE"
                android:pathPrefix="/external/"/>
        </provider>
        <provider
            android:label="@string/storage_description"
            android:name="MediaDocumentsProvider"
            android:permission="android.permission.MANAGE_DOCUMENTS"
            android:exported="true"
            android:authorities="com.android.providers.media.documents"
            android:grantUriPermissions="true">
            <intent-filter>
                <action android:name="android.content.action.DOCUMENTS_PROVIDER"/>
            </intent-filter>
        </provider>
        <receiver android:name="MediaUpgradeReceiver">
            <intent-filter>
                <action android:name="android.intent.action.PRE_BOOT_COMPLETED"/>
            </intent-filter>
        </receiver>
        <receiver android:name="MediaScannerReceiver">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.LOCALE_CHANGED"/>
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_MOUNTED"/>
                <data android:scheme="file"/>
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_UNMOUNTED"/>
                <data android:scheme="file"/>
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_SCANNER_SCAN_FILE"/>
                <data android:scheme="file"/>
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.ACTION_SHUTDOWN"/>
                <action android:name="mediatek.intent.action.ACTION_SHUTDOWN_IPO"/>
            </intent-filter>
            <intent-filter>
                <action android:name="mediatek.intent.action.OVERTIME_REMOVAL"/>
            </intent-filter>
        </receiver>
        <service
            android:name="MediaScannerService"
            android:exported="true">
            <intent-filter>
                <action android:name="android.media.IMediaScannerService"/>
            </intent-filter>
        </service>
        <receiver android:name="com.android.providers.media.MtpReceiver">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
            </intent-filter>
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_STATE"/>
            </intent-filter>
            <intent-filter>
                <action android:name="com.android.providers.media.ACTIVATE_MEDIAPROCESS"/>
            </intent-filter>
        </receiver>
        <receiver android:name="OmaReceiver">
            <intent-filter>
                <action android:name="com.mediatek.omacp.settings"/>
                <data android:mimeType="application/com.mediatek.omacp-554"/>
            </intent-filter>
            <intent-filter>
                <action android:name="com.mediatek.omacp.capability"/>
            </intent-filter>
        </receiver>
        <service android:name="MtpService"/>
        <activity
            android:theme="@style/PickerDialogTheme"
            android:name="RingtonePickerActivity"
            android:enabled="@android:^attr-private/dialogCustomTitleDecorLayout"
            android:excludeFromRecents="true">
            <intent-filter>
                <action android:name="android.intent.action.RINGTONE_PICKER"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
        </activity>
    </application>
</manifest>
