<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    android:sharedUserId="android.uid.phone"
    android:versionCode="28"
    android:versionName="9"
    android:compileSdkVersion="28"
    android:compileSdkVersionCodename="9"
    package="com.android.providers.telephony"
    coreApp="true"
    platformBuildVersionCode="28"
    platformBuildVersionName="9">
    <uses-sdk
        android:minSdkVersion="28"
        android:targetSdkVersion="28"/>
    <uses-permission android:name="android.permission.RECEIVE_SMS"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.INTERACT_ACROSS_USERS"/>
    <uses-permission android:name="android.permission.UPDATE_APP_OPS_STATS"/>
    <uses-permission android:name="android.permission.READ_CONTACTS"/>
    <uses-permission android:name="android.permission.WRITE_SETTINGS"/>
    <uses-permission android:name="android.permission.INTERACT_ACROSS_USERS_FULL"/>
    <uses-permission android:name="android.permission.USE_RESERVED_DISK"/>
    <protected-broadcast android:name="android.provider.action.EXTERNAL_PROVIDER_CHANGE"/>
    <protected-broadcast android:name="android.intent.action.CONTENT_CHANGED"/>
    <uses-permission android:name="android.permission.MODIFY_PHONE_STATE"/>
    <permission
        android:name="com.cmcc.ccs.READ_CCS_MESSAGE"
        android:protectionLevel="normal"/>
    <permission
        android:name="com.cmcc.ccs.WRITE_CCS_MESSAGE"
        android:protectionLevel="normal"/>
    <application
        android:label="@string/app_label"
        android:icon="@mipmap/ic_launcher_phone"
        android:allowClearUserData="false"
        android:process="com.android.phone"
        android:backupAgent="TelephonyBackupAgent"
        android:restoreAnyVersion="true"
        android:fullBackupOnly="true"
        android:usesCleartextTraffic="true"
        android:defaultToDeviceProtectedStorage="true"
        android:directBootAware="true"
        android:backupInForeground="true">
        <provider
            android:name="TelephonyProvider"
            android:exported="true"
            android:multiprocess="false"
            android:authorities="telephony"
            android:singleUser="true"/>
        <provider
            android:name="CbProvider"
            android:readPermission="android.permission.READ_SMS"
            android:exported="true"
            android:multiprocess="false"
            android:authorities="cb"
            android:singleUser="true"/>
        <provider
            android:name="ServiceStateProvider"
            android:writePermission="android.permission.MODIFY_PHONE_STATE"
            android:exported="true"
            android:multiprocess="false"
            android:authorities="service-state"
            android:singleUser="true"/>
        <provider
            android:name="SmsProvider"
            android:readPermission="android.permission.READ_SMS"
            android:exported="true"
            android:multiprocess="false"
            android:authorities="sms"
            android:singleUser="true"/>
        <provider
            android:name="WapPushProvider"
            android:readPermission="android.permission.READ_SMS"
            android:exported="true"
            android:multiprocess="false"
            android:authorities="wappush"
            android:singleUser="true"/>
        <provider
            android:name="MwiProvider"
            android:readPermission="android.permission.READ_SMS"
            android:exported="true"
            android:multiprocess="false"
            android:authorities="mwimsg"
            android:singleUser="true"/>
        <provider
            android:name="RCSProvider"
            android:readPermission="com.cmcc.ccs.READ_CCS_MESSAGE"
            android:writePermission="com.cmcc.ccs.WRITE_CCS_MESSAGE"
            android:exported="true"
            android:multiprocess="false"
            android:authorities="com.cmcc.ccs.message;com.cmcc.ccs.message_conversation;rcs;mms-sms-rcs"/>
        <provider
            android:name="MmsProvider"
            android:readPermission="android.permission.READ_SMS"
            android:exported="true"
            android:multiprocess="false"
            android:authorities="mms"
            android:singleUser="true">
            <grant-uri-permission android:pathPrefix="/part/"/>
            <grant-uri-permission android:pathPrefix="/drm/"/>
        </provider>
        <provider
            android:name="MmsSmsProvider"
            android:readPermission="android.permission.READ_SMS"
            android:exported="true"
            android:multiprocess="false"
            android:authorities="mms-sms"
            android:singleUser="true"/>
        <provider
            android:name="CarrierProvider"
            android:writePermission="android.permission.MODIFY_PHONE_STATE"
            android:exported="true"
            android:multiprocess="false"
            android:authorities="carrier_information"
            android:singleUser="true"/>
        <provider
            android:name="HbpcdLookupProvider"
            android:writePermission="android.permission.MODIFY_PHONE_STATE"
            android:exported="true"
            android:multiprocess="false"
            android:authorities="hbpcd_lookup"
            android:singleUser="true"/>
        <provider
            android:name="CarrierIdProvider"
            android:exported="true"
            android:multiprocess="false"
            android:authorities="carrier_id"
            android:singleUser="true"/>
        <service
            android:name="com.android.providers.telephony.TelephonyBackupAgent.DeferredSmsMmsRestoreService"
            android:exported="false"/>
        <provider
            android:name="UserSmsProvider"
            android:readPermission="android.permission.READ_SMS"
            android:writePermission="android.permission.WRITE_SMS"
            android:exported="true"
            android:multiprocess="false"
            android:authorities="usersms"/>
        <provider
            android:name="UserCBProvider"
            android:readPermission="android.permission.READ_SMS"
            android:writePermission="android.permission.WRITE_SMS"
            android:exported="true"
            android:multiprocess="false"
            android:authorities="usercb"/>
        <provider
            android:name="UserMmsProvider"
            android:readPermission="android.permission.READ_SMS"
            android:writePermission="android.permission.WRITE_SMS"
            android:exported="true"
            android:multiprocess="false"
            android:authorities="usermms">
            <grant-uri-permission android:pathPrefix="/part/"/>
            <grant-uri-permission android:pathPrefix="/drm/"/>
        </provider>
    </application>
</manifest>
